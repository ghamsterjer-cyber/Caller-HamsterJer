
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ВРЕМЕННО: Разрешаем всё для отладки и бесконфликтной работы звонилки.
    // Это гарантирует, что правила не блокируют сигналинг (Offer/Answer/ICE).
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
